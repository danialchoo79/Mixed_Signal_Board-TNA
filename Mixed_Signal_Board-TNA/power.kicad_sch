	(text "Note: \nHT7533-1 C Spec: >= 10u\nDue to voltage derating, ~+-20%\nSpec Up: 22u\nHence, 22u*0.2=4.4u -> 4.4V \nEffective Cap, 22u-4.4=17.6u \nAlso DC Bias reduces E.Cap, C = eA/d\nwhere e is permittivity of dielectric\ne decreases w applied DC E.Field, C decrease"
		(exclude_from_sim no)
		(at 81.28 84.582 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
				(italic yes)
			)
			(justify left)
		)
		(uuid "22fcd54c-0b57-4c85-8cba-71421396d3e4")
	)
