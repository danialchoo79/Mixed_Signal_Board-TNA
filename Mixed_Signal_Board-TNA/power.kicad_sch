	(text "L=[V_out*(V_in-V_out)]/(V_in*f_sw*delta_IL)\nwhere delta_IL = k*IL\nL=[3.3*(5-3.3)]/(5*1.5MHz*(0.25^0.25A)) = 12uH\nStandard Value = 15uH\nLighter Loads -> Larger Inductors"
		(exclude_from_sim no)
