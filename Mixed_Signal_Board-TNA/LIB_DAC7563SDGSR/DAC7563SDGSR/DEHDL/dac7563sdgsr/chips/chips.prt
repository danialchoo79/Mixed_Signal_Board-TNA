FILE_TYPE=LIBRARY_PARTS;
PRIMITIVE 'DAC7563SDGSR','DAC7563SDGSR_Small Outline Packages';
  PIN
    'VOUTA':
      PIN_NUMBER='(1)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'VOUTB':
      PIN_NUMBER='(2)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'GND':
      PIN_NUMBER='(3)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'LDAC*':
      PIN_NUMBER='(4)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'CLR*':
      PIN_NUMBER='(5)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'VREF_IN_/_VREFOUT':
      PIN_NUMBER='(10)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'AVDD':
      PIN_NUMBER='(9)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'DIN':
      PIN_NUMBER='(8)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'SCLK':
      PIN_NUMBER='(7)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'SYNC*':
      PIN_NUMBER='(6)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
  END_PIN;
  BODY
    PART_NAME='DAC7563SDGSR';
    PHYS_DES_PREFIX='IC';
    NO_LOAD_CHECK='TRUE';
    PIN_COUNT='10';
    BODY_NAME='DAC7563SDGSR';
    JEDEC_TYPE='SOP50P490X110-10N';
  END_BODY;
END_PRIMITIVE;
END.
